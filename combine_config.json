{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/user/projects"
      ]
    },
    "mui": {
      "command": "npx",
      "args": [
        "--no",
        "@mui/mcp"
      ]
    },
    "storybook-figma": {
      "command": "npx",
      "args": [
        "--no",
        "storybook-figma-mcp"
      ],
      "env": {
        "FIGMA_ACCESS_TOKEN": "figd_YOUR_TOKEN_HERE",
        "FIGMA_TEAM_ID": "YOUR_TEAM_ID"
      }
    },
    "tavily": {
      "command": "npx",
      "args": [
        "-y",
        "tavily-mcp"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "deep-research": {
      "command": "npx",
      "args": [
        "-y",
        "@pinkpixel/deep-research-mcp"
      ]
    },
    "repowise": {
      "command": "uvx",
      "args": [
        "repowise",
        "mcp"
      ]
    },
    "github": {
      "command": "npx",
      "args": [
        "--no",
        "github-mcp-server-mcp"
      ]
    }
  }
}